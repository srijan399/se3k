# SE3K MCP server config

# Groq (OpenAI-compatible) — get a free key at https://console.groq.com
GROQ_API_KEY=

# Optional overrides (defaults shown). Any OpenAI-compatible endpoint works.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant

# Semantic answer cache — embeds questions so repeated/reworded ones are served
# instantly with zero LLM calls. Optional: without a key the cache is disabled.
# Get a free key at https://jina.ai/embeddings
JINA_API_KEY=
# JINA_EMBED_MODEL=jina-embeddings-v3
# SEMANTIC_CACHE_THRESHOLD=0.72

# Where the JSON graph is persisted (defaults to ../graph-store/graph.json)
# GRAPH_STORE_PATH=

# --- Multi-workspace storage (Postgres via Drizzle) -------------------------
# Required. Every installation, graph node/edge, backfill job, and processed-
# message record is partitioned by team_id in this database.
DB_URL=

# HTTP port this process listens on — serves MCP over Streamable HTTP at
# POST/GET/DELETE /mcp (what slack-bot connects to) plus the REST routes
# under /internal/* and /graph (what web calls).
# MCP_PORT=4000

# Shared secret required on the x-internal-secret header for every /internal/*
# and /graph request, and for the MCP endpoint. Set the SAME value here, in
# slack-bot/.env, and in web/.env.local. hackathon shortcut: a single shared
# secret between services, not per-service auth — fine for a hackathon
# deployment, would harden before any production use.
INTERNAL_API_SECRET=
