{
  "display_information": {
    "name": "SE3K",
    "description": "Ask who actually knows about X — ranked by demonstrated involvement, not formal assignment.",
    "background_color": "#0b0b12"
  },
  "features": {
    "bot_user": {
      "display_name": "se3k",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/ask-graph",
        "description": "Ask who knows about X, or why a decision was made",
        "usage_hint": "who do I talk to about rate limiting?",
        "should_escape": false
      },
      {
        "command": "/se3k-ingest",
        "description": "Flush pending channel messages into the knowledge graph",
        "should_escape": false
      },
      {
        "command": "/se3k-backfill",
        "description": "Ingest recent channel history into the knowledge graph",
        "usage_hint": "[count]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "http://localhost:3030/callback",
      "http://localhost:3000/api/slack/oauth/callback"
    ],
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "groups:history",
        "channels:read",
        "groups:read",
        "channels:join",
        "chat:write",
        "commands",
        "users:read"
      ],
      "user": ["chat:write"]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
